<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đánh giá Nguy cơ Té ngã OFRAS</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Tailwind CSS Config for custom print styles -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        medical: {
                            50: '#f0fdfa',
                            100: '#ccfbf1',
                            500: '#14b8a6',
                            600: '#0d9488',
                            700: '#0f766e',
                            800: '#115e59',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @media print {
            body {
                background-color: white !important;
                color: black !important;
                font-size: 12px;
            }
            .no-print {
                display: none !important;
            }
            .print-border {
                border: 1px solid #ccc !important;
                border-radius: 4px;
            }
            .print-card {
                box-shadow: none !important;
                border: 1px solid #e5e7eb !important;
                margin-bottom: 15px !important;
                padding: 15px !important;
            }
            .print-bg-gray {
                background-color: #f3f4f6 !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen pb-12">

    <!-- Header / Banner -->
    <header class="bg-medical-700 text-white shadow-md no-print">
        <div class="max-w-4xl mx-auto px-4 py-5 flex items-center justify-between">
            <div class="flex items-center space-x-3">
                <!-- Medical Icon SVG -->
                <svg class="w-8 h-8 text-teal-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <div>
                    <h1 class="text-xl font-bold tracking-wide">PHẦN MỀM LÂM SÀNG</h1>
                    <p class="text-xs text-teal-100 uppercase tracking-widest">Đánh giá nguy cơ té ngã cho sản phụ</p>
                </div>
            </div>
            <div class="text-sm text-right hidden sm:block">
                <p class="font-medium text-teal-200">Thang điểm OFRAS</p>
                <p class="text-xs opacity-75">Chuẩn hóa Quy trình Chăm sóc Sản khoa</p>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 mt-6">
        
        <!-- Hospital/Institution Header for PRINT -->
        <div class="hidden print:block mb-6">
            <div class="flex justify-between items-start border-b pb-4">
                <div>
                    <p class="font-bold text-sm uppercase">SỞ Y TẾ / BỆNH VIỆN PHỤ SẢN</p>
                    <p class="text-xs">Khoa: ................................................</p>
                </div>
                <div class="text-right">
                    <h2 class="text-base font-bold uppercase">PHIẾU ĐÁNH GIÁ NGUY CƠ TÉ NGÃ OFRAS</h2>
                    <p class="text-xs text-gray-500">(Áp dụng cho người bệnh sản khoa - Phụ lục 6)</p>
                </div>
            </div>
        </div>

        <!-- Flow Container: Questionnaire then Results -->
        <div class="space-y-6">
            
            <!-- SECTION 1: Questionnaire Cards -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden print-card">
                <div class="p-6 space-y-6">
                    
                    <!-- CARD 1: Prior History (Tiền sử trước đây) -->
                    <div class="category-group" data-category="prior_history">
                        <div class="flex items-center justify-between border-b pb-2 mb-3">
                            <h3 class="font-bold text-slate-800 flex items-center">
                                <span class="w-6 h-6 rounded-full bg-medical-600 text-white text-xs flex items-center justify-center mr-2">1</span>
                                Prior History (Tiền sử trước đây)
                            </h3>
                            <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-semibold group-score">0 điểm</span>
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="ph" value="0" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded" checked>
                                <span class="flex-grow">Không có</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">0đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="ph" value="1" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có sử dụng kính có gọng/kính áp tròng kê đơn, nhưng hiện tại không đeo</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">1đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="ph" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có tiền sử nằm bất động tại giường (trong vòng 2 tháng qua)</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="ph" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có tiền sử té ngã (ngay trước đó hoặc trong vòng 3 tháng qua)</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="ph" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Suy giảm thị lực nghiêm trọng (vượt quá mức có thể điều chỉnh bằng kính gọng hoặc kính áp tròng)</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                        </div>
                    </div>

                    <!-- CARD 2: Cardiovascular (Tim mạch) -->
                    <div class="category-group" data-category="cardiovascular">
                        <div class="flex items-center justify-between border-b pb-2 mb-3">
                            <h3 class="font-bold text-slate-800 flex items-center">
                                <span class="w-6 h-6 rounded-full bg-medical-600 text-white text-xs flex items-center justify-center mr-2">2</span>
                                Cardiovascular (Tim mạch)
                            </h3>
                            <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-semibold group-score">0 điểm</span>
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="cv" value="0" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded" checked>
                                <span class="flex-grow">Không có</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">0đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="cv" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Chóng mặt</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="cv" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có tiền sử thiếu máu và/hoặc tiền sản giật</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="cv" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Hạ huyết áp tư thế đứng</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                        </div>
                    </div>

                    <!-- CARD 3: Hemorrhage (Xuất huyết) -->
                    <div class="category-group" data-category="hemorrhage">
                        <div class="flex items-center justify-between border-b pb-2 mb-3">
                            <h3 class="font-bold text-slate-800 flex items-center">
                                <span class="w-6 h-6 rounded-full bg-medical-600 text-white text-xs flex items-center justify-center mr-2">3</span>
                                Hemorrhage (Xuất huyết)
                            </h3>
                            <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-semibold group-score">0 điểm</span>
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="he" value="0" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded" checked>
                                <span class="flex-grow">Không có</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">0đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="he" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Cắt tử cung</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="he" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Được chẩn đoán nhau bong non hoặc nhau tiền đạo</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="he" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Băng huyết sau sinh lớn hơn 500 ml</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                        </div>
                    </div>

                    <!-- CARD 4: Anesthesia / Cognition (Gây tê / Nhận thức) -->
                    <div class="category-group" data-category="anesthesia">
                        <div class="flex items-center justify-between border-b pb-2 mb-3">
                            <h3 class="font-bold text-slate-800 flex items-center">
                                <span class="w-6 h-6 rounded-full bg-medical-600 text-white text-xs flex items-center justify-center mr-2">4</span>
                                Anesthesia / Cognition (Gây tê / Nhận thức)
                            </h3>
                            <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-semibold group-score">0 điểm</span>
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="0" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded" checked>
                                <span class="flex-grow">Không gây tê ngoài màng cứng hoặc gây tê tủy sống</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">0đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Tê bì ở vùng đùi</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Hiện đang truyền thuốc gây tê ngoài màng cứng liên tục</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Đã tắt/rút gây tê ngoài màng cứng chưa đầy 3 giờ</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Gây tê tủy sống trong vòng 12 giờ đầu tiên</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="an" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Biến đổi nhận thức / Suy giảm nhận thức</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                        </div>
                    </div>

                    <!-- CARD 5: Motor / Activity (Vận động / Hoạt động) -->
                    <div class="category-group" data-category="motor">
                        <div class="flex items-center justify-between border-b pb-2 mb-3">
                            <h3 class="font-bold text-slate-800 flex items-center">
                                <span class="w-6 h-6 rounded-full bg-medical-600 text-white text-xs flex items-center justify-center mr-2">5</span>
                                Motor / Activity (Vận động / Hoạt động)
                            </h3>
                            <span class="text-xs bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full font-semibold group-score">0 điểm</span>
                        </div>
                        <div class="space-y-2">
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="mo" value="0" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded" checked>
                                <span class="flex-grow">Có thể cử động chân – tự đi lại độc lập</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">0đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="mo" value="1" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có thể cử động chân – đi lại cần dụng cụ hỗ trợ (ví dụ: khung tập đi, gậy, v.v.)</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">1đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="mo" value="2" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Có thể nhấc thẳng chân (SLR) nhưng không thể làm động tác cầu bập bênh (nâng hông khỏi giường ở tư thế nằm ngửa, đầu gối gập 90 độ)</span>
                                <span class="text-slate-500 font-semibold ml-2 w-8 text-right">2đ</span>
                            </label>
                            <label class="flex items-start p-2 rounded hover:bg-slate-50 cursor-pointer text-sm">
                                <input type="checkbox" name="mo" value="3" class="mt-1 mr-3 h-4 w-4 text-medical-600 focus:ring-medical-500 border-gray-300 rounded">
                                <span class="flex-grow">Không thể nhấc thẳng chân (SLR)</span>
                                <span class="text-red-600 font-bold ml-2 w-8 text-right">3đ ⚠️</span>
                            </label>
                        </div>
                    </div>

                </div>
            </div>

            <!-- SECTION 2: Evaluation Results Panel (At the Bottom) -->
            <div class="bg-white rounded-xl shadow-md border-2 border-slate-200 overflow-hidden print-card">
                <div class="bg-slate-800 text-white px-6 py-4 flex justify-between items-center print-bg-gray print:text-black">
                    <span class="font-bold tracking-wide uppercase">KẾT QUẢ ĐÁNH GIÁ CHUNG</span>
                    <span class="text-xs bg-slate-700 text-slate-300 px-2 py-0.5 rounded font-mono no-print">Live</span>
                </div>

                <div class="p-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
                        
                        <!-- Left inside column: Score & Risk Visual -->
                        <div class="space-y-4">
                            <!-- Score Display -->
                            <div class="text-center bg-slate-50 rounded-xl p-4 border border-slate-100 print-bg-gray">
                                <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Tổng điểm OFRAS</span>
                                <div class="flex items-baseline justify-center mt-1">
                                    <span id="total_score" class="text-6xl font-extrabold text-slate-800 tracking-tight transition-all duration-300">0</span>
                                    <span class="text-slate-400 font-bold text-lg ml-1">/ 15</span>
                                </div>
                            </div>

                            <!-- Risk Classification Indicator -->
                            <div>
                                <span class="block text-xs font-semibold text-slate-400 uppercase mb-2 text-center">Phân loại mức độ nguy cơ</span>
                                
                                <!-- Low Risk -->
                                <div id="risk_low" class="flex flex-col items-center bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg p-4 transition-all duration-300">
                                    <span class="text-2xl font-black uppercase tracking-wide">THẤP</span>
                                    <span class="text-xs text-emerald-600 mt-1 font-medium">(Phạm vi điểm: 0 - 2 điểm)</span>
                                </div>

                                <!-- Medium Risk -->
                                <div id="risk_medium" class="hidden flex flex-col items-center bg-amber-50 border border-amber-200 text-amber-800 rounded-lg p-4 transition-all duration-300">
                                    <span class="text-2xl font-black uppercase tracking-wide">TRUNG BÌNH</span>
                                    <span class="text-xs text-amber-600 mt-1 font-medium">(Phạm vi điểm: 3 - 4 điểm)</span>
                                </div>

                                <!-- High Risk -->
                                <div id="risk_high" class="hidden flex flex-col items-center bg-rose-50 border border-rose-200 text-rose-800 rounded-lg p-4 transition-all duration-300">
                                    <span class="text-2xl font-black uppercase tracking-wide">CAO</span>
                                    <span id="high_risk_reason" class="text-xs text-rose-600 mt-1 font-semibold text-center"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Right inside column: Reference Table & Action Buttons -->
                        <div class="space-y-4">
                            <!-- Standard Reference Mini-Table -->
                            <div class="border border-slate-100 rounded-lg p-3 bg-slate-50 print-bg-gray">
                                <p class="text-xs font-bold text-slate-700 uppercase mb-2">4.2. Khung phân loại nguy cơ:</p>
                                <div class="space-y-1.5 text-xs">
                                    <div class="flex justify-between text-emerald-700 font-semibold border-b border-dashed border-slate-200 pb-1">
                                        <span>0 - 2 điểm</span>
                                        <span>Mức nguy cơ THẤP</span>
                                    </div>
                                    <div class="flex justify-between text-amber-700 font-semibold border-b border-dashed border-slate-200 pb-1">
                                        <span>3 - 4 điểm</span>
                                        <span>Mức nguy cơ TRUNG BÌNH</span>
                                    </div>
                                    <div class="flex justify-between text-rose-700 font-bold">
                                        <span>&ge; 5 điểm (hoặc đạt 3đ đơn lẻ)</span>
                                        <span>Mức nguy cơ CAO</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Interactive Buttons -->
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 no-print">
                                <button onclick="window.print()" class="w-full bg-medical-600 hover:bg-medical-700 text-white font-bold py-2.5 px-4 rounded-lg transition duration-200 flex items-center justify-center space-x-2 shadow">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                                    </svg>
                                    <span>In kết quả (A4)</span>
                                </button>
                                <button onclick="resetForm()" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-600 font-semibold py-2.5 px-4 rounded-lg transition duration-150">
                                    Xóa & Làm lại
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Print Only Signatures Section -->
            <div class="hidden print:grid grid-cols-2 gap-4 mt-8 text-center text-xs">
                <div>
                    <p class="italic">Ngày ...... tháng ...... năm 20......</p>
                    <p class="font-bold uppercase mt-1">SẢN PHỤ / NGƯỜI NHÀ</p>
                    <p class="text-slate-400 mt-12">(Ký và ghi rõ họ tên)</p>
                </div>
                <div>
                    <p class="italic">Ngày ...... tháng ...... năm 20......</p>
                    <p class="font-bold uppercase mt-1">NGƯỜI ĐÁNH GIÁ (ĐD/HS/BS)</p>
                    <p class="text-slate-400 mt-12">(Ký và ghi rõ họ tên)</p>
                </div>
            </div>

        </div>

    </main>

    <!-- Script to calculate score dynamically -->
    <script>
        window.onload = function() {
            // Initialize event listeners
            initListeners();
            calculateOfrasScore();
        };

        function initListeners() {
            // Select all checkbox inputs
            const groups = document.querySelectorAll('.category-group');

            groups.forEach(group => {
                const checkboxes = group.querySelectorAll('input[type="checkbox"]');
                const zeroCheckbox = Array.from(checkboxes).find(cb => cb.value === "0");

                checkboxes.forEach(cb => {
                    cb.addEventListener('change', function() {
                        if (this.value === "0" && this.checked) {
                            // If "Không có" is checked, uncheck all other checkboxes in this group
                            checkboxes.forEach(otherCb => {
                                if (otherCb !== zeroCheckbox) otherCb.checked = false;
                            });
                        } else if (this.value !== "0" && this.checked) {
                            // If any other option is checked, uncheck "Không có" in this group
                            if (zeroCheckbox) zeroCheckbox.checked = false;
                        }

                        // Ensure at least "Không có" is checked if nothing is checked
                        const anyChecked = Array.from(checkboxes).some(otherCb => otherCb.checked);
                        if (!anyChecked && zeroCheckbox) {
                            zeroCheckbox.checked = true;
                        }

                        // Update current score calculation
                        calculateOfrasScore();
                    });
                });
            });
        }

        function calculateOfrasScore() {
            let total = 0;
            let hasItemScore3 = false;
            let groupScores = {
                prior_history: 0,
                cardiovascular: 0,
                hemorrhage: 0,
                anesthesia: 0,
                motor: 0
            };

            const groups = document.querySelectorAll('.category-group');

            groups.forEach(group => {
                const category = group.getAttribute('data-category');
                const checkedBoxes = group.querySelectorAll('input[type="checkbox"]:checked');
                let groupSum = 0;

                checkedBoxes.forEach(cb => {
                    const score = parseInt(cb.value);
                    groupSum += score;
                    if (score === 3) {
                        hasItemScore3 = true;
                    }
                });

                groupScores[category] = groupSum;
                total += groupSum;

                // Update UI badge for the category
                const badge = group.querySelector('.group-score');
                if (badge) {
                    badge.innerText = `${groupSum} điểm`;
                    if (groupSum > 0) {
                        badge.classList.remove('bg-slate-100', 'text-slate-600');
                        badge.classList.add('bg-medical-100', 'text-medical-800');
                    } else {
                        badge.classList.remove('bg-medical-100', 'text-medical-800');
                        badge.classList.add('bg-slate-100', 'text-slate-600');
                    }
                }
            });

            // Update Total Score on UI
            const scoreDisplay = document.getElementById('total_score');
            scoreDisplay.innerText = total;

            // Determine Risk Level
            const lowBox = document.getElementById('risk_low');
            const mediumBox = document.getElementById('risk_medium');
            const highBox = document.getElementById('risk_high');
            const highReasonText = document.getElementById('high_risk_reason');

            // Hide all first
            lowBox.classList.add('hidden');
            mediumBox.classList.add('hidden');
            highBox.classList.add('hidden');

            // Logic classification
            if (total >= 5 || hasItemScore3) {
                highBox.classList.remove('hidden');
                scoreDisplay.className = "text-6xl font-extrabold text-rose-600 tracking-tight transition-all duration-300";
                
                // Reason for high risk
                if (hasItemScore3 && total < 5) {
                    highReasonText.innerText = `(Có bất kỳ tiêu chí nào đạt mức 3đ đơn lẻ)`;
                } else {
                    highReasonText.innerText = `(Phạm vi điểm: ≥ 5 điểm)`;
                }
            } else if (total >= 3 && total <= 4) {
                mediumBox.classList.remove('hidden');
                scoreDisplay.className = "text-6xl font-extrabold text-amber-500 tracking-tight transition-all duration-300";
            } else {
                lowBox.classList.remove('hidden');
                scoreDisplay.className = "text-6xl font-extrabold text-emerald-600 tracking-tight transition-all duration-300";
            }
        }

        function resetForm() {
            const checkboxes = document.querySelectorAll('input[type="checkbox"]');
            checkboxes.forEach(cb => {
                if (cb.value === "0") {
                    cb.checked = true;
                } else {
                    cb.checked = false;
                }
            });

            calculateOfrasScore();
        }
    </script>
</body>
</html>