<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biểu mẫu Giáo Dục Sức Khỏe - GDSK-01 (Tích hợp)</title>
    <!-- Vue 3 CDN -->
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        @media print {
            body {
                background: white;
                color: black;
            }
            .no-print {
                display: none !important;
            }
            .print-area {
                display: block !important;
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
                box-shadow: none !important;
            }
            .page-break {
                page-break-before: always;
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen">
    <div id="app" class="w-full flex flex-col min-h-screen" v-cloak>
        
        <!-- HEADER (no-print) -->
        <header class="bg-white border-b border-slate-200 py-3 px-6 flex justify-between items-center no-print shadow-xs">
            <div class="flex items-center gap-3">
                <span class="bg-emerald-50 text-emerald-600 p-2 rounded-lg">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                </span>
                <div>
                    <h2 class="text-base font-bold text-slate-800">Phân hệ Tư vấn & Giáo dục sức khỏe (GDSK-01)</h2>
                    <p class="text-xs text-slate-500">Mẫu tích hợp hệ thống - Nhập liệu nhanh & Xuất dữ liệu lưu trữ</p>
                </div>
            </div>

            <div class="flex items-center gap-2">
                <!-- Nút ẩn hiện Developer Tools -->
                <button @click="showDevConsole = !showDevConsole" :class="['px-3 py-1.5 text-xs font-semibold rounded border transition-all flex items-center gap-1', showDevConsole ? 'bg-amber-100 border-amber-300 text-amber-800' : 'bg-slate-100 border-slate-300 text-slate-700']">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                    {{ showDevConsole ? 'Ẩn Hộp Giả Lập' : 'Mở Hộp Giả Lập Tích Hợp' }}
                </button>
                <button @click="triggerPrint" class="px-4 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-xs font-semibold rounded shadow-xs hover:shadow transition-all flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                    In Phiếu (Gộp)
                </button>
            </div>
        </header>

        <!-- HỘP CÔNG CỤ GIẢ LẬP TÍCH HỢP (no-print) -->
        <section v-if="showDevConsole" class="bg-amber-50 border-b border-amber-200 p-4 no-print">
            <div class="max-w-6xl mx-auto">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="text-xs font-bold text-amber-900 uppercase tracking-wider flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Hộp Giả Lập Truyền Nhận Dữ Liệu từ App Tổng của bạn
                    </h3>
                    <span class="text-[10px] bg-amber-200 text-amber-800 px-2 py-0.5 rounded font-mono font-bold">API ACTIVE</span>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                    <!-- Bên trái: Điền thông tin nhanh để test -->
                    <div class="bg-white p-3 rounded border border-amber-200 space-y-2">
                        <p class="font-semibold text-amber-950 mb-1">1. Giả lập thay đổi thông tin hành chính từ App Tổng:</p>
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" v-model="currentPatient.facility" placeholder="Cơ sở y tế" class="border p-1 rounded col-span-2 bg-amber-50 font-medium">
                            <input type="text" v-model="currentPatient.fullName" placeholder="Họ và tên người bệnh" class="border p-1 rounded w-full">
                            <input type="text" v-model="currentPatient.patientCode" placeholder="Mã người bệnh" class="border p-1 rounded w-full">
                            <input type="text" v-model="currentPatient.hospitalId" placeholder="Số vào viện" class="border p-1 rounded w-full">
                            <input type="number" v-model="currentPatient.age" placeholder="Tuổi" class="border p-1 rounded w-full">
                            <select v-model="currentPatient.gender" class="border p-1 rounded w-full">
                                <option value="Nam">Giới tính: Nam</option>
                                <option value="Nữ">Giới tính: Nữ</option>
                            </select>
                            <input type="text" v-model="currentPatient.department" placeholder="Khoa điều trị" class="border p-1 rounded w-full">
                            <input type="text" v-model="currentPatient.room" placeholder="Phòng" class="border p-1 rounded w-full">
                            <input type="text" v-model="currentPatient.bed" placeholder="Giường" class="border p-1 rounded w-full">
                        </div>
                        <p class="text-[10px] text-slate-500 italic mt-1">* Dữ liệu này sẽ tự động liên kết vào bản in A4 và luồng dữ liệu của hệ thống.</p>
                    </div>

                    <!-- Bên phải: Hướng dẫn kết nối JS API -->
                    <div class="bg-slate-900 text-slate-200 p-3 rounded font-mono text-[11px] flex flex-col justify-between">
                        <div>
                            <p class="text-amber-400 font-bold mb-1">// API KẾT NỐI VỚI APP TỔNG CỦA BẠN:</p>
                            <p class="text-slate-400 mb-2">Bạn có thể gọi trực tiếp các hàm này từ iframe hoặc console:</p>
                            <div class="space-y-1">
                                <p><span class="text-blue-400">window.GDSK_API.loadPatient</span>(dataObj);</p>
                                <p><span class="text-blue-400">window.GDSK_API.exportData</span>(); <span class="text-emerald-400">// Lấy JSON đã chọn để lưu DB</span></p>
                            </div>
                        </div>
                        <div class="mt-2 pt-2 border-t border-slate-800 flex justify-end gap-2">
                            <button @click="testExport" class="bg-amber-500 hover:bg-amber-600 text-slate-950 font-bold px-3 py-1 rounded transition-colors text-[10px]">
                                Test Export dữ liệu (Xem Console)
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- MAIN INTERFACE (no-print) -->
        <main class="flex-1 p-6 max-w-6xl w-full mx-auto space-y-6 no-print">
            
            <!-- ĐANG CHỈNH SỬA CHO BỆNH NHÂN NÀO -->
            <div class="bg-white border border-slate-200 rounded-lg p-3 px-4 flex justify-between items-center shadow-xs">
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-xs text-slate-500">Bệnh viện: <strong class="text-slate-800">{{ currentPatient.facility }}</strong></span>
                    <span class="text-slate-300">|</span>
                    <span class="text-xs text-slate-500">Người bệnh:</span>
                    <strong class="text-slate-800 text-sm">{{ currentPatient.fullName || '(Chưa nhập tên)' }}</strong>
                    <span class="text-slate-300">|</span>
                    <span class="text-xs text-slate-600">Mã BN: <strong class="text-slate-800">{{ currentPatient.patientCode || 'N/A' }}</strong></span>
                    <span class="text-slate-300">|</span>
                    <span class="text-xs text-slate-600">Khoa: <strong class="text-slate-800">{{ currentPatient.department || 'N/A' }}</strong></span>
                </div>
                <span class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded">Mã biểu mẫu: GDSK-01</span>
            </div>

            <!-- NAVIGATION / FORM STAGE SELECTOR -->
            <div class="flex flex-col sm:flex-row gap-2 border-b border-slate-200 pb-1">
                <button @click="currentTab = 'phase1'"
                    :class="['flex-1 py-3 px-4 rounded-t-lg font-semibold text-sm transition-all flex items-center justify-center gap-2 border-b-2',
                             currentTab === 'phase1' ? 'bg-white text-emerald-600 border-emerald-500 shadow-xs' : 'text-slate-500 hover:text-slate-800 border-transparent hover:bg-slate-100']">
                    <span class="w-5 h-5 rounded-full bg-emerald-50 flex items-center justify-center text-xs text-emerald-600 font-bold">I</span>
                    Khi bắt đầu nhập viện
                </button>
                <button @click="currentTab = 'phase2'"
                    :class="['flex-1 py-3 px-4 rounded-t-lg font-semibold text-sm transition-all flex items-center justify-center gap-2 border-b-2',
                             currentTab === 'phase2' ? 'bg-white text-blue-600 border-blue-500 shadow-xs' : 'text-slate-500 hover:text-slate-800 border-transparent hover:bg-slate-100']">
                    <span class="w-5 h-5 rounded-full bg-blue-50 flex items-center justify-center text-xs text-blue-600 font-bold">II</span>
                    Trong khi điều trị
                </button>
                <button @click="currentTab = 'phase3'"
                    :class="['flex-1 py-3 px-4 rounded-t-lg font-semibold text-sm transition-all flex items-center justify-center gap-2 border-b-2',
                             currentTab === 'phase3' ? 'bg-white text-amber-600 border-amber-500 shadow-xs' : 'text-slate-500 hover:text-slate-800 border-transparent hover:bg-slate-100']">
                    <span class="w-5 h-5 rounded-full bg-amber-50 flex items-center justify-center text-xs text-amber-600 font-bold">III</span>
                    Trước khi ra viện
                </button>
                <button @click="currentTab = 'combined'"
                    :class="['flex-1 py-3 px-4 rounded-t-lg font-semibold text-sm transition-all flex items-center justify-center gap-2 border-b-2',
                             currentTab === 'combined' ? 'bg-white text-purple-600 border-purple-500 shadow-xs' : 'text-slate-500 hover:text-slate-800 border-transparent hover:bg-slate-100']">
                    <span>
                        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 12v-6m-9-3H7a2 2 0 00-2 2v3h2v-3zm3-3h-2v3h2v-3zm3-3h-2v3h2v-3zM9 8h.01M9 12h.01M9 16h.01M13 16h.01M13 12h.01M13 8h.01M17 16h.01M17 12h.01M17 8h.01"></path></svg>
                    </span>
                    Bản Gộp In Ấn (Gồm cả 3 phần)
                </button>
            </div>

            <!-- SUB-FORMS CONTAINER -->
            <div class="bg-white rounded-xl shadow-xs border border-slate-200 p-6 min-h-[400px]">

                <!-- PHÍM TẮT NHANH CHO CÁC BẢNG -->
                <div v-if="currentTab !== 'combined'" class="mb-4 flex flex-wrap justify-between items-center gap-2 bg-slate-50 p-3 rounded-lg border border-slate-200">
                    <span class="text-xs font-semibold text-slate-500">Phím tắt nhanh:</span>
                    <div class="flex gap-2">
                        <button @click="quickAction('co')" class="px-2.5 py-1 bg-white hover:bg-emerald-50 text-emerald-700 text-xs font-medium rounded border border-emerald-200 transition-colors">
                            ✓ Chọn tất cả "Có"
                        </button>
                        <button @click="quickAction('không')" class="px-2.5 py-1 bg-white hover:bg-red-50 text-red-700 text-xs font-medium rounded border border-red-200 transition-colors">
                            ✗ Chọn tất cả "Không"
                        </button>
                        <button @click="quickAction('hthd')" class="px-2.5 py-1 bg-white hover:bg-blue-50 text-blue-700 text-xs font-medium rounded border border-blue-200 transition-colors">
                            ★ Chọn tất cả "Hoàn thành (HTHD)"
                        </button>
                        <button @click="quickAction('reset')" class="px-2.5 py-1 bg-white hover:bg-slate-100 text-slate-600 text-xs font-medium rounded border border-slate-200 transition-colors">
                            Xóa hết chọn
                        </button>
                    </div>
                </div>

                <!-- TAB I: KHI BẮT ĐẦU NHẬP VIỆN -->
                <div v-if="currentTab === 'phase1'">
                    <div class="mb-4">
                        <h4 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                            <span class="px-2 py-0.5 bg-emerald-100 text-emerald-800 text-xs rounded-full">Phần I</span>
                            Tư vấn, hướng dẫn khi bắt đầu nhập viện
                        </h4>
                    </div>

                    <div class="overflow-x-auto border border-slate-200 rounded-lg">
                        <table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="bg-slate-50 text-slate-600 border-b border-slate-200">
                                    <th class="py-3 px-4 font-semibold w-12 text-center">TT</th>
                                    <th class="py-3 px-4 font-semibold">Nội dung hướng dẫn</th>
                                    <th class="py-3 px-4 font-semibold w-40 text-center border-l border-slate-200">Nhu cầu hướng dẫn</th>
                                    <th class="py-3 px-4 font-semibold w-52 text-center border-l border-slate-200">Kết quả hướng dẫn</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <tr v-for="(item, idx) in currentPatient.phase1.items" :key="item.id" class="hover:bg-slate-50/50">
                                    <td class="py-3 px-4 text-center font-medium text-slate-400">{{ idx + 1 }}</td>
                                    <td class="py-3 px-4 font-medium text-slate-700">{{ item.content }}</td>
                                    <td class="py-3 px-4 border-l border-slate-200">
                                        <div class="flex justify-center gap-4">
                                            <label class="inline-flex items-center cursor-pointer">
                                                <input type="radio" :name="'p1-need-'+item.id" value="Có" v-model="item.need" class="text-emerald-600 focus:ring-emerald-500">
                                                <span class="ml-1 text-xs">Có</span>
                                            </label>
                                            <label class="inline-flex items-center cursor-pointer">
                                                <input type="radio" :name="'p1-need-'+item.id" value="Không" v-model="item.need" class="text-slate-600 focus:ring-slate-500">
                                                <span class="ml-1 text-xs">Không</span>
                                            </label>
                                        </div>
                                    </td>
                                    <td class="py-3 px-4 border-l border-slate-200">
                                        <div class="flex justify-center gap-3">
                                            <label class="inline-flex items-center cursor-pointer" title="Đã được hướng dẫn nhưng cần hướng dẫn thêm">
                                                <input type="radio" :name="'p1-res-'+item.id" value="HDTh" v-model="item.result" class="text-amber-500 focus:ring-amber-400">
                                                <span class="ml-1 text-xs font-semibold text-amber-600">HDTh</span>
                                            </label>
                                            <label class="inline-flex items-center cursor-pointer" title="Hoàn thành hướng dẫn (Không cần hướng dẫn thêm)">
                                                <input type="radio" :name="'p1-res-'+item.id" value="HTHD" v-model="item.result" class="text-emerald-600 focus:ring-emerald-500">
                                                <span class="ml-1 text-xs font-semibold text-emerald-600">HTHD</span>
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Chữ ký & thời điểm -->
                    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6 bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Thời điểm tư vấn</label>
                            <input type="date" v-model="currentPatient.phase1.date" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Người thực hiện tư vấn</label>
                            <input type="text" v-model="currentPatient.phase1.staffName" placeholder="Tên điều dưỡng / bác sĩ" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Người bệnh / Thân nhân ký</label>
                            <input type="text" v-model="currentPatient.phase1.patientSign" placeholder="Tên người ký nhận" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                    </div>
                </div>

                <!-- TAB II: TRONG KHI VÀO VIỆN / ĐIỀU TRỊ -->
                <div v-if="currentTab === 'phase2'">
                    <div class="mb-4">
                        <h4 class="text-sm font-bold text-slate-800 flex items-center gap-2">
                            <span class="px-2 py-0.5 bg-blue-100 text-blue-800 text-xs rounded-full">Phần II</span>
                            Tư vấn, hướng dẫn trong khi vào viện (Quá trình điều trị)
                        </h4>
                    </div>

                    <div class="overflow-x-auto border border-slate-200 rounded-lg">
                        <table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="bg-slate-50 text-slate-600 border-b border-slate-200">
                                    <th class="py-3 px-4 font-semibold w-12 text-center">TT</th>
                                    <th class="py-3 px-4 font-semibold">Nội dung hướng dẫn</th>
                                    <th class="py-3 px-4 font-semibold w-40 text-center border-l border-slate-200">Nhu cầu hướng dẫn</th>
                                    <th class="py-3 px-4 font-semibold w-52 text-center border-l border-slate-200">Kết quả hướng dẫn</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                <tr v-for="(item, idx) in currentPatient.phase2.items" :key="item.id" class="hover:bg-slate-50/50">
                                    <td class="py-3 px-4 text-center font-medium text-slate-400">{{ idx + 1 }}</td>
                                    <td class="py-3 px-4 font-medium text-slate-700">{{ item.content }}</td>
                                    <td class="py-3 px-4 border-l border-slate-200">
                                        <div class="flex justify-center gap-4">
                                            <label class="inline-flex items-center cursor-pointer">
                                                <input type="radio" :name="'p2-need-'+item.id" value="Có" v-model="item.need" class="text-blue-600 focus:ring-blue-500">
                                                <span class="ml-1 text-xs">Có</span>
                                            </label>
                                            <label class="inline-flex items-center cursor-pointer">
                                                <input type="radio" :name="'p2-need-'+item.id" value="Không" v-model="item.need" class="text-slate-600 focus:ring-slate-500">
                                                <span class="ml-1 text-xs">Không</span>
                                            </label>
                                        </div>
                                    </td>
                                    <td class="py-3 px-4 border-l border-slate-200">
                                        <div class="flex justify-center gap-3">
                                            <label class="inline-flex items-center cursor-pointer" title="Đã được hướng dẫn nhưng cần hướng dẫn thêm">
                                                <input type="radio" :name="'p2-res-'+item.id" value="HDTh" v-model="item.result" class="text-amber-500 focus:ring-amber-400">
                                                <span class="ml-1 text-xs font-semibold text-amber-600">HDTh</span>
                                            </label>
                                            <label class="inline-flex items-center cursor-pointer" title="Hoàn thành hướng dẫn (Không cần hướng dẫn thêm)">
                                                <input type="radio" :name="'p2-res-'+item.id" value="HTHD" v-model="item.result" class="text-emerald-600 focus:ring-emerald-500">
                                                <span class="ml-1 text-xs font-semibold text-emerald-600">HTHD</span>
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Chữ ký & thời điểm -->
                    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6 bg-slate-50 p-4 rounded-xl border border-slate-200">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Thời điểm tư vấn</label>
                            <input type="date" v-model="currentPatient.phase2.date" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Người thực hiện tư vấn</label>
                            <input type="text" v-model="currentPatient.phase2.staffName" placeholder="Tên điều dưỡng / bác sĩ" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Người bệnh / Thân nhân ký</label>
                            <input type="text" v-model="currentPatient.phase2.patientSign" placeholder="Tên người ký nhận" class="w-full border border-slate-300 rounded px-3 py-1.5 text-sm focus:ring-1 focus:ring-emerald-500 focus:outline-none">
                        </div>
                    </div>
