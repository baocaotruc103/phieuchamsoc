        const defaultPhase2Items = () => [
            { id: '2_1', content: "Giải thích các kỹ thuật, thủ thuật trước, trong và sau khi thực hiện trên người bệnh liên quan đến công tác chăm sóc.", need: null, result: null },
            { id: '2_2', content: "Hướng dẫn sử dụng thuốc an toàn và hiệu quả.", need: null, result: null },
            { id: '2_3', content: "Hướng dẫn tự phát hiện và theo dõi các triệu chứng khác thường", need: null, result: null },
            { id: '2_4', content: "Hướng dẫn chế độ dinh dưỡng theo bệnh lý, tương tác giữa thực phẩm và thuốc (nếu có).", need: null, result: null },
            { id: '2_5', content: "Hướng dẫn các vấn đề an toàn người bệnh: Đề phòng té ngã, loét do tì đè.", need: null, result: null },
            { id: '2_6', content: "Hướng dẫn chế độ vận động theo bệnh lý, nghỉ ngơi hợp lý.", need: null, result: null },
            { id: '2_7', content: "Hướng dẫn chăm sóc vệ sinh cá nhân.", need: null, result: null },
            { id: '2_8', content: "Tìm hiểu nhu cầu và hỗ trợ người bệnh “Giai đoạn cuối” về thể chất - tinh thần.", need: null, result: null }
        ];

        const defaultPhase3Items = () => [
            { id: '3_1', content: "Chăm sóc tại nhà sau khi xuất viện", need: null, result: null },
            { id: '3_2', content: "Điều trị và dùng thuốc", need: null, result: null },
            { id: '3_3', content: "Thời gian và nơi thực hiện việc theo dõi chăm sóc", need: null, result: null },
            { id: '3_4', content: "Khi nào phải liên hệ với bác sỹ", need: null, result: null },
            { id: '3_5', content: "Khi nào cần phải đi khám, chăm sóc khẩn cấp", need: null, result: null }
        ];

        const createEmptyPatient = () => ({
            facility: 'Bệnh viện Quân y 103',
            hospitalId: '',
            patientCode: '',
            fullName: '',
            age: '',
            gender: 'Nam',
            department: '',
            room: '',
            bed: '',
            phase1: {
                date: new Date().toISOString().substring(0, 10),
                staffName: '',
                patientSign: '',
                items: defaultPhase1Items()
            },
            phase2: {
                date: new Date().toISOString().substring(0, 10),
                staffName: '',
                patientSign: '',
                items: defaultPhase2Items()
            },
            phase3: {
                date: new Date().toISOString().substring(0, 10),
                staffName: '',
                patientSign: '',
                items: defaultPhase3Items()
            }
        });

        // Component Tài liệu GDSK
        const PatientGdsDocument = {
            name: 'PatientGdsDocument',
            template: '#patient-gds-document-template',
            props: {
                patient: {
                    type: Object,
                    required: true
                },
                isPrint: {
                    type: Boolean,
                    default: false
                }
            },
            methods: {
                formatDate(val) {
                    if (!val) return '........./........./20.........';
                    try {
                        const parts = val.split('-');
                        if(parts.length === 3) {
                            return `${parts[2]}/${parts[1]}/${parts[0]}`;
                        }
                    } catch(e) {}
                    return val;
                }
            }
        };

        const app = createApp({
            components: {
                PatientGdsDocument
            },
            setup() {
                const currentPatient = ref(createEmptyPatient());
                const currentTab = ref('phase1');
                const showDevConsole = ref(true); // Hiển thị sẵn công cụ giả lập tích hợp

                // Khởi tạo bệnh nhân giả lập lúc đầu
                onMounted(() => {
                    // Dữ liệu mẫu demo
                    const demoData = {
                        fullName: 'Trần Quốc Bảo',
                        patientCode: 'BN-88902',
                        hospitalId: 'VV-3342',
                        age: 38,
                        gender: 'Nam',
                        facility: 'Bệnh viện Quân y 103',
                        department: 'Tim Mạch Can Thiệp',
                        room: 'P.402',
                        bed: '09',
                        phase1: {
                            date: '2026-05-20',
                            staffName: 'ĐD. Nguyễn Hoàng Yến',
                            patientSign: 'Trần Quốc Bảo',
                            items: defaultPhase1Items()
                        },
                        phase2: {
                            date: '2026-05-20',
                            staffName: 'ĐD. Nguyễn Hoàng Yến',
                            patientSign: 'Trần Quốc Bảo',
                            items: defaultPhase2Items()
                        },
                        phase3: {
                            date: '2026-05-20',
                            staffName: 'ĐD. Nguyễn Hoàng Yến',
                            patientSign: 'Trần Quốc Bảo',
                            items: defaultPhase3Items()
                        }
                    };
                    currentPatient.value = demoData;

                    // Đăng ký API toàn cục trên window để App tổng gọi
                    window.GDSK_API = {
                        // 1. Hàm nạp dữ liệu từ App Tổng
                        loadPatient: (patientData) => {
                            if (!patientData) return;
                            
                            // Đảm bảo dữ liệu các phần có cấu trúc mảng chuẩn
                            const p1Items = patientData.phase1?.items || defaultPhase1Items();
                            const p2Items = patientData.phase2?.items || defaultPhase2Items();
                            const p3Items = patientData.phase3?.items || defaultPhase3Items();

                            currentPatient.value = {
                                facility: patientData.facility || 'Bệnh viện Quân y 103',
                                hospitalId: patientData.hospitalId || '',
                                patientCode: patientData.patientCode || '',
                                fullName: patientData.fullName || '',
                                age: patientData.age || '',
                                gender: patientData.gender || 'Nam',
                                department: patientData.department || '',
                                room: patientData.room || '',
                                bed: patientData.bed || '',
                                phase1: {
                                    date: patientData.phase1?.date || new Date().toISOString().substring(0, 10),
                                    staffName: patientData.phase1?.staffName || '',
                                    patientSign: patientData.phase1?.patientSign || '',
                                    items: p1Items
                                },
                                phase2: {
                                    date: patientData.phase2?.date || new Date().toISOString().substring(0, 10),
                                    staffName: patientData.phase2?.staffName || '',
                                    patientSign: patientData.phase2?.patientSign || '',
                                    items: p2Items
                                },
                                phase3: {
                                    date: patientData.phase3?.date || new Date().toISOString().substring(0, 10),
                                    staffName: patientData.phase3?.staffName || '',
                                    patientSign: patientData.phase3?.patientSign || '',
                                    items: p3Items
                                }
                            };
                            console.log("GDSK-01: Đã nhận dữ liệu người bệnh từ App Tổng!");
                        },

                        // 2. Hàm xuất dữ liệu tích chọn ngược lại cho App Tổng
                        exportData: () => {
                            return JSON.parse(JSON.stringify(currentPatient.value));
                        }
                    };
                });

                const resetCurrentPatientForm = () => {
                    if (confirm("Reset lại toàn bộ dữ liệu lựa chọn trên bảng tích?")) {
                        currentPatient.value.phase1.items = defaultPhase1Items();
                        currentPatient.value.phase2.items = defaultPhase2Items();
                        currentPatient.value.phase3.items = defaultPhase3Items();
                    }
                };

                const quickAction = (actionType) => {
                    const currentPhase = currentTab.value;
                    if (!currentPatient.value[currentPhase]) return;

                    const items = currentPatient.value[currentPhase].items;
                    items.forEach(item => {
                        if (actionType === 'co') {
                            item.need = 'Có';
                        } else if (actionType === 'không') {
                            item.need = 'Không';
                            item.result = null;
                        } else if (actionType === 'hthd') {
                            item.need = 'Có';
                            item.result = 'HTHD';
                        } else if (actionType === 'reset') {
                            item.need = null;
                            item.result = null;
                        }
                    });
                };

                const triggerPrint = () => {
                    window.print();
                };

                const saveAndNotify = () => {
                    const result = window.GDSK_API.exportData();
                    console.log("Kết quả Export cho App Tổng:", result);
                    
                    // Gửi Event ra ngoài cho App Tổng bắt (Nếu tích hợp trong iframe / micro-frontend)
                    const event = new CustomEvent('gdskSave', { detail: result });
                    window.dispatchEvent(event);
                    if (window.parent) {
                        window.parent.postMessage({ type: 'GDSK_SAVE', data: result }, '*');
                    }

                    alert("Đã kết xuất dữ liệu thành công! Hãy kiểm tra tab Console để xem cấu trúc JSON lưu trữ.");
                };

                const testExport = () => {
                    const data = window.GDSK_API.exportData();
                    console.log("👉 Dữ liệu hiện tại của biểu mẫu:", data);
                    alert("Đã ghi nhận dữ liệu tại Developer Console. Ấn F12 để kiểm tra!");
                };

                return {
                    currentTab,
                    currentPatient,
                    showDevConsole,
                    resetCurrentPatientForm,
                    quickAction,
                    triggerPrint,
                    saveAndNotify,
                    testExport
                };
            }
        });

        app.mount('#app');
    </script>
</body>
</html>