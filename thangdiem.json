      },
      {
        "min": 1,
        "max": 3,
        "label": "Đau nhẹ",
        "color": "lime",
        "recommendation": "Theo dõi mức độ đau, hướng dẫn thư giãn, thay đổi tư thế nếu phù hợp."
      },
      {
        "min": 4,
        "max": 6,
        "label": "Đau vừa",
        "color": "orange",
        "recommendation": "Đánh giá lại nguyên nhân đau, thực hiện giảm đau theo y lệnh, báo bác sĩ nếu cần."
      },
      {
        "min": 7,
        "max": 10,
        "label": "Đau nặng",
        "color": "red",
        "recommendation": "Ưu tiên đánh giá nguyên nhân, báo bác sĩ ngay, thực hiện can thiệp giảm đau khẩn."
      }
    ],
    "calculationLogic": {
      "functionName": "calculatePainVAS",
      "javascript": "function calculatePainVAS(score){const vas=Number(score);if(isNaN(vas)||vas<0||vas>10){return{valid:false,score:null,label:'',color:'gray',recommendation:'Điểm đau không hợp lệ (0-10)'}};if(vas===0){return{valid:true,score:vas,label:'Không đau',color:'green',recommendation:'Tiếp tục theo dõi tình trạng người bệnh.'}};if(vas<=3){return{valid:true,score:vas,label:'Đau nhẹ',color:'lime',recommendation:'Theo dõi mức độ đau, hướng dẫn thư giãn, thay đổi tư thế nếu phù hợp.'}};if(vas<=6){return{valid:true,score:vas,label:'Đau vừa',color:'orange',recommendation:'Đánh giá lại nguyên nhân đau, thực hiện giảm đau theo y lệnh, báo bác sĩ nếu cần.'}};return{valid:true,score:vas,label:'Đau nặng',color:'red',recommendation:'Ưu tiên đánh giá nguyên nhân, báo bác sĩ ngay, thực hiện can thiệp giảm đau khẩn.'}}"
    },
    "display": {
      "showScore": true,
      "showLevel": true,
      "showRecommendation": true,
      "showColorIndicator": true
    },
    "validation": {
      "required": false,
      "minValue": 0,
      "maxValue": 10
    }
  },
